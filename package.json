{
	"name": "nspin",
	"description": "Lightweight and efficient Node.js spinner package using native features",
	"version": "1.8.0",
	"license": "MIT",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"keywords": [
		"cli",
		"spinner",
		"terminal",
		"node",
		"esm",
		"commonjs"
	],
	"homepage": "https://github.com/ManuelGil/nspin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/nspin.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/nspin/issues"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.ts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"!dist/**/*.map"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "vite build && pnpm run build:types",
		"build:types": "tsc --emitDeclarationOnly && node -e \"fs.copyFileSync('dist/index.d.ts','dist/index.d.cts')\"",
		"dev": "vite build --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"ts-check": "tsc --noEmit",
		"check-exports": "attw --pack --ignore-rules cjs-resolves-to-esm",
		"audit": "pnpm audit",
		"validate": "pnpm run check && pnpm run ts-check && pnpm run test && pnpm run build && pnpm run check-exports",
		"pack:check": "pnpm pack",
		"release": "release-it",
		"prepare": "pnpm exec husky",
		"prepublishOnly": "pnpm run validate && cp README.npm.md README.md",
		"postpublish": "git checkout -- README.md"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@biomejs/biome": "^2.5.0",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/node": "^22.19.21",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"release-it": "^19.2.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.16",
		"vite-plugin-dts": "^5.0.2",
		"vitest": "^3.2.6"
	},
	"lint-staged": {
		"*.{ts,js,json,md}": [
			"biome check --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: :bookmark: release ${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": true
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		},
		"hooks": {
			"before:init": "pnpm run validate",
			"before:release": "pnpm run build"
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"husky"
		],
		"overrides": {
			"undici@<6.24.0": ">=6.24.0",
			"esbuild@>=0.27.3 <0.28.1": ">=0.28.1"
		}
	}
}
